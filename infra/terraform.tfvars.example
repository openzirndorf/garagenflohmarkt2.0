# Kopieren nach terraform.tfvars und ausfüllen (wird NICHT eingecheckt)
#
# Hinweis: Die SMTP-Variablen können alternativ direkt im Scaleway-Webinterface gesetzt werden:
#   Serverless Containers → flohmarkt-api → Environment Variables
# Das ist einfacher, wenn du keinen lokalen tofu apply machen willst.

scw_access_key      = "SCW_ACCESS_KEY_HIER"
scw_secret_key      = "SCW_SECRET_KEY_HIER"
scw_project_id      = "PROJECT_ID_HIER"
admin_token         = "EIN_LANGES_ZUFAELLIGES_GEHEIMNIS"
api_username        = "flohmarkt"
api_password        = "EIN_ANDERES_LANGES_ZUFAELLIGES_GEHEIMNIS"
container_image_tag = "latest"
# database_url wird automatisch aus scaleway_sdb_sql_database.flohmarkt.endpoint abgeleitet

# SMTP – Scaleway Transactional Email, wird automatisch aus main.tf gesetzt:
#   SMTP_HOST     = smtp.tem.scaleway.com  (hardcoded)
#   SMTP_PORT     = 465                    (hardcoded, SSL)
#   SMTP_USER     = scw_project_id         (hardcoded)
#   SMTP_PASSWORD = scw_secret_key         (hardcoded)
smtp_from     = "noreply@automail.DEINE_DOMAIN.de"  # Absenderadresse, muss in Scaleway TEM verifiziert sein

# Öffentliche Backend-URL (für Bestätigungslinks in E-Mails)
# Beim ersten Deploy leer lassen (""), nach Apply mit Container-URL befüllen
backend_url   = "https://api.DEINE_DOMAIN.de"
frontend_url  = "https://openzirndorf.github.io/garagenflohmarkt2.0"
